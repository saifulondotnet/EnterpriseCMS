@inject EnterpriseCMS.Core.Interfaces.IUnitOfWork uow
@{
    string areaSlug = ViewBag.WidgetArea as string ?? "sidebar";
    var widgets = (await uow.Widgets.FindAsync(w => w.AreaSlug == areaSlug && w.IsActive))
        .OrderBy(w => w.Order).ToList();
}
@foreach (var widget in widgets)
{
    <div class="widget mb-4">
        @if (!string.IsNullOrEmpty(widget.Title))
        {
            <h5 class="widget-title fw-semibold mb-3">@widget.Title</h5>
        }
        @switch (widget.WidgetType)
        {
            case "text":
                <div class="widget-content">@Html.Raw(widget.Settings)</div>
                break;
            case "html":
                @Html.Raw(widget.Settings)
                break;
            default:
                <p class="text-muted small">[@widget.WidgetType widget]</p>
                break;
        }
    </div>
}
