<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - @ViewData["SiteName"]</title>
    @if (ViewData["MetaDescription"] != null)
    {
        <meta name="description" content="@ViewData["MetaDescription"]" />
    }
    <!-- Open Graph -->
    <meta property="og:title" content="@(ViewData["Title"]?.ToString() ?? ViewData["SiteName"]?.ToString())" />
    <meta property="og:type" content="website" />
    @if (ViewData["MetaDescription"] != null)
    {
        <meta property="og:description" content="@ViewData["MetaDescription"]" />
    }
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@(ViewData["Title"]?.ToString() ?? ViewData["SiteName"]?.ToString())" />
    <!-- Schema.org JSON-LD -->
    @if (ViewData["SchemaOrg"] != null)
    {
        <script type="application/ld+json">@Html.Raw(ViewData["SchemaOrg"])</script>
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/themes/CMS-Clean/css/cms-clean.css" />
    @if (ViewData["CustomCss"] != null)
    {
        <style>@Html.Raw(ViewData["CustomCss"])</style>
    }
</head>
<body>
    @await Html.PartialAsync("_Navigation")
    <main>
        @RenderBody()
    </main>
    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0 small">&copy; @DateTime.UtcNow.Year @(ViewData["SiteName"] ?? "EnterpriseCMS"). All rights reserved.</p>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
