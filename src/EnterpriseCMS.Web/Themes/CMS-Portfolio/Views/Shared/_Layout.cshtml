<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - @(ViewData["SiteName"] ?? "Portfolio")</title>
    @if (ViewData["MetaDescription"] != null)
    {
        <meta name="description" content="@ViewData["MetaDescription"]" />
    }
    <meta property="og:title" content="@(ViewData["Title"]?.ToString() ?? "")" />
    <meta property="og:type" content="website" />
    @if (ViewData["SchemaOrg"] != null)
    {
        <script type="application/ld+json">@Html.Raw(ViewData["SchemaOrg"])</script>
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/themes/CMS-Portfolio/css/theme.css" />
    @if (ViewData["CustomCss"] != null)
    {
        <style>@Html.Raw(ViewData["CustomCss"])</style>
    }
</head>
<body class="portfolio-theme">
    <header class="site-header">
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                <a class="navbar-brand fw-bold text-uppercase letter-spacing-2" href="/">
                    @(ViewData["SiteName"] ?? "Portfolio")
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#portfolioNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="portfolioNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item"><a class="nav-link" href="/">Work</a></li>
                        <li class="nav-item"><a class="nav-link" href="/about">About</a></li>
                        <li class="nav-item"><a class="nav-link" href="/contact">Contact</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <main class="portfolio-main">
        @RenderBody()
    </main>
    <footer class="portfolio-footer bg-black text-white py-5">
        <div class="container text-center">
            <p class="mb-0 text-muted small">&copy; @DateTime.UtcNow.Year @(ViewData["SiteName"] ?? "Portfolio")</p>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
