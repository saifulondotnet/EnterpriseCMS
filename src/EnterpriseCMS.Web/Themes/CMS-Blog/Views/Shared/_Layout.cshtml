<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - @(ViewData["SiteName"] ?? "Blog")</title>
    @if (ViewData["MetaDescription"] != null)
    {
        <meta name="description" content="@ViewData["MetaDescription"]" />
    }
    <meta property="og:title" content="@(ViewData["Title"]?.ToString() ?? "")" />
    <meta property="og:type" content="article" />
    @if (ViewData["MetaDescription"] != null)
    {
        <meta property="og:description" content="@ViewData["MetaDescription"]" />
    }
    <meta name="twitter:card" content="summary_large_image" />
    @if (ViewData["SchemaOrg"] != null)
    {
        <script type="application/ld+json">@Html.Raw(ViewData["SchemaOrg"])</script>
    }
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="/themes/CMS-Blog/css/theme.css" />
    @if (ViewData["CustomCss"] != null)
    {
        <style>@Html.Raw(ViewData["CustomCss"])</style>
    }
</head>
<body class="blog-theme">
    <header class="blog-header border-bottom bg-white sticky-top">
        <div class="container py-3">
            <div class="d-flex justify-content-between align-items-center">
                <a class="blog-brand text-decoration-none" href="/">
                    <span class="fw-black fs-4 text-dark">@(ViewData["SiteName"] ?? "Blog")</span>
                </a>
                <nav class="d-none d-md-flex gap-4 align-items-center">
                    <a class="nav-link text-dark" href="/">Home</a>
                    <a class="nav-link text-dark" href="/blog">Articles</a>
                    <a class="nav-link text-dark" href="/about">About</a>
                    <a class="nav-link text-dark" href="/contact">Contact</a>
                </nav>
                <button class="navbar-toggler d-md-none border-0" type="button" data-bs-toggle="collapse" data-bs-target="#blogNav">
                    <i class="bi bi-list fs-4"></i>
                </button>
            </div>
            <div class="collapse" id="blogNav">
                <div class="d-flex flex-column gap-2 py-3">
                    <a class="nav-link" href="/">Home</a>
                    <a class="nav-link" href="/blog">Articles</a>
                    <a class="nav-link" href="/about">About</a>
                </div>
            </div>
        </div>
    </header>
    <div class="container my-5">
        <div class="row">
            <main class="col-lg-8 col-xl-9">
                @RenderBody()
            </main>
            <aside class="col-lg-4 col-xl-3 blog-sidebar">
                @await Html.PartialAsync("_WidgetArea", "sidebar")
            </aside>
        </div>
    </div>
    <footer class="blog-footer bg-light border-top mt-5 py-5">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5 class="fw-bold">@(ViewData["SiteName"] ?? "Blog")</h5>
                    <p class="text-muted small">A place for thoughts, ideas, and stories.</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="text-muted small mb-0">&copy; @DateTime.UtcNow.Year @(ViewData["SiteName"] ?? "Blog"). All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
