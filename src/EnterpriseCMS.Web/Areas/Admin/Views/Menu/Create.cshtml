@using EnterpriseCMS.Application.Common.Models
@model MenuDto
@{
    ViewData["Title"] = "Create Menu";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fs-5 fw-bold">Create Menu</h2>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>
<div class="card border-0 shadow-sm" style="max-width:500px">
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Name</label>
                <input type="text" name="Name" class="form-control" required placeholder="Main Navigation" />
            </div>
            <div class="mb-3">
                <label class="form-label">Slug</label>
                <input type="text" name="Slug" class="form-control" required placeholder="main-nav" />
            </div>
            <div class="mb-3">
                <label class="form-label">Location</label>
                <select name="Location" class="form-select">
                    <option value="primary">Primary</option>
                    <option value="footer">Footer</option>
                    <option value="sidebar">Sidebar</option>
                </select>
            </div>
            <button type="submit" class="btn btn-primary">Create Menu</button>
        </form>
    </div>
</div>
