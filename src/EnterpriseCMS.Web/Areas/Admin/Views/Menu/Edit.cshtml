@using EnterpriseCMS.Application.Common.Models
@model MenuDto
@{
    ViewData["Title"] = "Edit Menu: " + Model.Name;
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fs-5 fw-bold">Edit: @Model.Name</h2>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>
<div class="row g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header fw-semibold">Menu Details</div>
            <div class="card-body">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input type="text" name="Name" class="form-control" value="@Model.Name" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Slug</label>
                        <input type="text" name="Slug" class="form-control" value="@Model.Slug" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Location</label>
                        <select name="Location" class="form-select">
                            <option value="primary" @(Model.Location=="primary"?"selected":"")>Primary</option>
                            <option value="footer" @(Model.Location=="footer"?"selected":"")>Footer</option>
                            <option value="sidebar" @(Model.Location=="sidebar"?"selected":"")>Sidebar</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary">Save Details</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Menu Items</span>
                <button class="btn btn-sm btn-primary" id="addItemBtn"><i class="bi bi-plus-lg"></i> Add Item</button>
            </div>
            <div class="card-body">
                <div id="menu-builder" style="min-height:100px">
                    <!-- items rendered by JS -->
                </div>
            </div>
            <div class="card-footer">
                <button class="btn btn-success" id="saveItemsBtn"><i class="bi bi-check-lg me-1"></i>Save Items</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/jquery-ui@1.13.3/themes/base/jquery-ui.min.css" />
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jquery-ui@1.13.3/dist/jquery-ui.min.js"></script>
<script>
$(function() {
    var items = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Items));
    var $builder = $('#menu-builder');

    function renderItems(list, $container, depth) {
        depth = depth || 0;
        $.each(list, function(i, item) {
            var $item = $('<div class="menu-item border rounded p-2 mb-1 bg-white d-flex align-items-center gap-2">')
                .css('margin-left', (depth * 24) + 'px')
                .data('item', item);
            $item.append('<span class="bi bi-grip-vertical text-muted drag-handle" style="cursor:grab"></span>');
            $item.append('<span class="flex-grow-1 fw-semibold">' + $('<div>').text(item.label).html() + '</span>');
            $item.append('<small class="text-muted">' + $('<div>').text(item.url || '').html() + '</small>');
            $item.append('<button class="btn btn-xs btn-outline-danger btn-sm remove-item py-0 px-1"><i class="bi bi-trash"></i></button>');
            $container.append($item);
            if (item.children && item.children.length) renderItems(item.children, $container, depth + 1);
        });
    }

    renderItems(items, $builder, 0);

    $builder.sortable({ handle: '.drag-handle' });

    $('#addItemBtn').on('click', function() {
        var label = prompt('Item Label:');
        if (!label) return;
        var url = prompt('URL (leave blank for #):') || '#';
        var $item = $('<div class="menu-item border rounded p-2 mb-1 bg-white d-flex align-items-center gap-2">')
            .data('item', { label: label, url: url, target: '_self', sortOrder: 0, children: [] });
        $item.append('<span class="bi bi-grip-vertical text-muted drag-handle" style="cursor:grab"></span>');
        $item.append('<span class="flex-grow-1 fw-semibold">' + $('<div>').text(label).html() + '</span>');
        $item.append('<small class="text-muted">' + $('<div>').text(url).html() + '</small>');
        $item.append('<button class="btn btn-sm btn-outline-danger remove-item py-0 px-1"><i class="bi bi-trash"></i></button>');
        $builder.append($item);
    });

    $(document).on('click', '.remove-item', function() { $(this).closest('.menu-item').remove(); });

    $('#saveItemsBtn').on('click', function() {
        var menuItems = [];
        var order = 0;
        $('.menu-item').each(function() {
            var d = $(this).data('item') || {};
            menuItems.push({ label: d.label || '', url: d.url || '', target: d.target || '_self', sortOrder: order++, children: [] });
        });
        $.ajax({
            url: '@Url.Action("SaveItems")',
            method: 'POST',
            contentType: 'application/json',
            data: JSON.stringify({ menuId: '@Model.Id', items: menuItems }),
            headers: { 'RequestVerificationToken': $('input[name=__RequestVerificationToken]').val() },
            success: function() { alert('Menu items saved!'); },
            error: function() { alert('Error saving items.'); }
        });
    });
});
</script>
}
