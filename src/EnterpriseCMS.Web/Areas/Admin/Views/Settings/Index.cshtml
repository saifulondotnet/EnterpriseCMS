@{
    ViewData["Title"] = "Settings";
}
@model Dictionary<string, List<EnterpriseCMS.Core.Entities.Setting>>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-gear me-2"></i>Settings</h2>
</div>
<form asp-action="Save" method="post">
    @Html.AntiForgeryToken()
    @foreach (var group in Model)
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold">@group.Key</div>
            <div class="card-body">
                @foreach (var setting in group.Value)
                {
                    <div class="mb-3">
                        <label class="form-label">@(setting.Description ?? setting.SettingKey)</label>
                        <input type="text" name="values[@setting.SettingKey]" value="@setting.SettingValue" class="form-control form-control-sm" @(setting.IsSystem ? "readonly" : "") />
                    </div>
                }
            </div>
        </div>
    }
    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save Settings</button>
</form>
