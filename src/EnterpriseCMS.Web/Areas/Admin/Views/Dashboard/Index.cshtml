@{
    ViewData["Title"] = "Dashboard";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-speedometer2 me-2"></i>Dashboard</h2>
</div>
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3"><i class="bi bi-file-earmark-text fs-4 text-primary"></i></div>
                <div><div class="text-muted small">Total Content</div><div class="fs-4 fw-bold">@ViewBag.ContentCount</div></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3"><i class="bi bi-check-circle fs-4 text-success"></i></div>
                <div><div class="text-muted small">Published</div><div class="fs-4 fw-bold">@ViewBag.PublishedCount</div></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-warning bg-opacity-10 p-3"><i class="bi bi-pencil-square fs-4 text-warning"></i></div>
                <div><div class="text-muted small">Drafts</div><div class="fs-4 fw-bold">@ViewBag.DraftCount</div></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-info bg-opacity-10 p-3"><i class="bi bi-images fs-4 text-info"></i></div>
                <div><div class="text-muted small">Media Assets</div><div class="fs-4 fw-bold">@ViewBag.MediaCount <small class="text-muted fs-6">(@ViewBag.TotalMediaSizeMb MB)</small></div></div>
            </div>
        </div>
    </div>
</div>
<div class="row g-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-clock-history me-2"></i>Recent Content</div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>Title</th><th>Type</th><th>Status</th><th>Date</th></tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.RecentContent != null)
                        {
                            foreach (var item in ViewBag.RecentContent)
                            {
                                <tr>
                                    <td>@item.Title</td>
                                    <td><span class="badge bg-secondary">@item.ContentType</span></td>
                                    <td>
                                        @{
                                            var statusClass = item.Status.ToString() == "Published" ? "success" : item.Status.ToString() == "Draft" ? "warning" : "secondary";
                                        }
                                        <span class="badge bg-@statusClass">@item.Status</span>
                                    </td>
                                    <td class="text-muted small">@item.Date.ToString("MMM d, yyyy")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="text-center text-muted py-3">No content yet</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-lightning me-2"></i>Quick Actions</div>
            <div class="card-body d-flex flex-column gap-2">
                <a asp-area="Admin" asp-controller="Content" asp-action="Create" asp-route-contentType="page" class="btn btn-outline-primary"><i class="bi bi-plus me-1"></i>New Page</a>
                <a asp-area="Admin" asp-controller="Content" asp-action="Create" asp-route-contentType="post" class="btn btn-outline-primary"><i class="bi bi-plus me-1"></i>New Post</a>
                <a asp-area="Admin" asp-controller="Media" asp-action="Index" class="btn btn-outline-success"><i class="bi bi-upload me-1"></i>Upload Media</a>
            </div>
        </div>
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold"><i class="bi bi-heart-pulse me-2"></i>System Health</div>
            <div class="card-body">
                @if (ViewBag.SystemHealthy == true)
                {
                    <div class="d-flex align-items-center gap-2 text-success">
                        <i class="bi bi-check-circle-fill"></i>
                        <span>All systems operational</span>
                    </div>
                }
                else
                {
                    <div class="d-flex align-items-center gap-2 text-danger">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <span>Issues detected</span>
                    </div>
                }
                <hr />
                <a href="/health" target="_blank" class="btn btn-sm btn-outline-secondary w-100">View Health Report</a>
            </div>
        </div>
    </div>
</div>
