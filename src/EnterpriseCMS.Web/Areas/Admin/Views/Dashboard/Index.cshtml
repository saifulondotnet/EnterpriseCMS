@{
    ViewData["Title"] = "Dashboard";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-speedometer2 me-2"></i>Dashboard</h2>
</div>
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-primary bg-opacity-10 p-3"><i class="bi bi-file-earmark-text fs-4 text-primary"></i></div>
                <div><div class="text-muted small">Total Content</div><div class="fs-4 fw-bold">@ViewBag.ContentCount</div></div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-circle bg-success bg-opacity-10 p-3"><i class="bi bi-images fs-4 text-success"></i></div>
                <div><div class="text-muted small">Media Assets</div><div class="fs-4 fw-bold">@ViewBag.MediaCount</div></div>
            </div>
        </div>
    </div>
</div>
<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold">Quick Actions</div>
            <div class="card-body d-flex flex-column gap-2">
                <a asp-area="Admin" asp-controller="Content" asp-action="Create" asp-route-contentType="page" class="btn btn-outline-primary"><i class="bi bi-plus me-1"></i>New Page</a>
                <a asp-area="Admin" asp-controller="Content" asp-action="Create" asp-route-contentType="post" class="btn btn-outline-primary"><i class="bi bi-plus me-1"></i>New Post</a>
                <a asp-area="Admin" asp-controller="Media" asp-action="Index" class="btn btn-outline-success"><i class="bi bi-upload me-1"></i>Upload Media</a>
            </div>
        </div>
    </div>
</div>
