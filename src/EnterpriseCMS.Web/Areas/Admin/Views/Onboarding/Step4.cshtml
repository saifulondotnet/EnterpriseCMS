@{
    ViewData["Title"] = "Setup — Step 4";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <div class="progress mb-2" style="height:6px">
                    <div class="progress-bar" style="width:80%"></div>
                </div>
                <h5 class="mb-0"><i class="bi bi-file-earmark-plus me-2"></i>Step 4 of 5 — Sample Content</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">Optionally install sample pages and posts to get started quickly.</p>
                <form asp-action="Step4Post" method="post">
                    @Html.AntiForgeryToken()
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" name="installSamples" id="installSamples" />
                        <label class="form-check-label" for="installSamples">Install sample content (Home, About, Blog Post)</label>
                    </div>
                    <div class="d-flex justify-content-between">
                        <a asp-action="Step3" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
                        <button type="submit" class="btn btn-primary">Next <i class="bi bi-arrow-right ms-1"></i></button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
