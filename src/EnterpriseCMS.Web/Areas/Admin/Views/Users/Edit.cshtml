@model EnterpriseCMS.Core.Entities.ApplicationUser
@{
    ViewData["Title"] = "Edit User";
    var userRoles = (IList<string>)(ViewBag.UserRoles ?? new List<string>());
    var currentRole = userRoles.FirstOrDefault() ?? "";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-person-gear me-2"></i>Edit User</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to Users</a>
</div>
<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">First Name</label>
                    <input type="text" name="firstName" class="form-control" value="@Model.FirstName" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Last Name</label>
                    <input type="text" name="lastName" class="form-control" value="@Model.LastName" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Display Name</label>
                    <input type="text" name="displayName" class="form-control" value="@Model.DisplayName" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Email</label>
                    <input type="email" class="form-control" value="@Model.Email" disabled />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Role</label>
                    <select name="role" class="form-select" required>
                        @foreach (var role in (IEnumerable<string>)(ViewBag.Roles ?? new List<string>()))
                        {
                            <option value="@role" @(role == currentRole ? "selected" : "")>@role</option>
                        }
                    </select>
                </div>
                <div class="col-12 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <form asp-action="Deactivate" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-outline-warning" type="submit">@(Model.IsActive ? "Deactivate" : "Activate") Account</button>
                    </form>
                </div>
            </div>
        </form>
    </div>
</div>
