<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - EnterpriseCMS Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar" class="bg-dark text-white d-none d-lg-flex flex-column p-3" style="width:250px;min-height:100vh">
            <a href="/Admin" class="text-white text-decoration-none mb-3">
                <h5 class="mb-0"><i class="bi bi-grid-3x3-gap-fill me-2"></i>EnterpriseCMS</h5>
            </a>
            <hr class="border-secondary" />
            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString()=="Dashboard"?"active":"")">
                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-area="Admin" asp-controller="Content" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString()=="Content"?"active":"")">
                        <i class="bi bi-file-earmark-text me-2"></i>Content
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-area="Admin" asp-controller="Media" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString()=="Media"?"active":"")">
                        <i class="bi bi-images me-2"></i>Media
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-area="Admin" asp-controller="Menu" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString()=="Menu"?"active":"")">
                        <i class="bi bi-list-nested me-2"></i>Menus
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-area="Admin" asp-controller="Widget" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString()=="Widget"?"active":"")">
                        <i class="bi bi-layout-sidebar me-2"></i>Widgets
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-area="Admin" asp-controller="Redirect" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString()=="Redirect"?"active":"")">
                        <i class="bi bi-arrow-left-right me-2"></i>Redirects
                    </a>
                </li>
                <li class="nav-item">
                    <a asp-area="Admin" asp-controller="Settings" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString()=="Settings"?"active":"")">
                        <i class="bi bi-gear me-2"></i>Settings
                    </a>
                </li>
                @if (User.IsInRole("SuperAdmin") || User.IsInRole("Administrator"))
                {
                    <li class="nav-item">
                        <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="nav-link text-white @(ViewContext.RouteData.Values["controller"]?.ToString()=="Users"?"active":"")">
                            <i class="bi bi-people me-2"></i>Users
                        </a>
                    </li>
                }
            </ul>
            <hr class="border-secondary" />
            <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post">
                @Html.AntiForgeryToken()
                <button class="btn btn-outline-light btn-sm w-100" type="submit">
                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                </button>
            </form>
        </nav>
        <!-- Main content -->
        <div id="content" class="flex-grow-1 bg-light">
            <nav class="navbar navbar-expand navbar-light bg-white border-bottom px-3 py-2">
                <button class="btn btn-sm btn-outline-secondary me-2 d-lg-none" id="sidebarToggle"><i class="bi bi-list"></i></button>
                <div class="ms-auto d-flex align-items-center gap-2">
                    <!-- Notification Bell -->
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary position-relative" id="notificationBell" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-bell"></i>
                            @{
                                var notifications = TempData["Notifications"] as List<string> ?? new List<string>();
                            }
                            @if (notifications.Any())
                            {
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:.65rem">
                                    @notifications.Count
                                </span>
                            }
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end" style="min-width:280px;max-width:320px">
                            <li><h6 class="dropdown-header">Notifications</h6></li>
                            @if (notifications.Any())
                            {
                                foreach (var n in notifications.Take(5))
                                {
                                    <li><a class="dropdown-item small" href="#">@n</a></li>
                                }
                            }
                            else
                            {
                                <li><span class="dropdown-item text-muted small">No new notifications</span></li>
                            }
                        </ul>
                    </div>
                    <!-- Dark Mode Toggle -->
                    <button class="btn btn-sm btn-outline-secondary" id="themeToggle" title="Toggle dark mode">
                        <i class="bi bi-moon"></i>
                    </button>
                    <span class="text-muted small">@User.Identity?.Name</span>
                </div>
            </nav>
            <!-- Mobile sidebar overlay -->
            <div id="mobileSidebar" class="d-lg-none position-fixed top-0 start-0 h-100 bg-dark text-white flex-column p-3" style="width:250px;z-index:1050;display:none!important">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0 text-white"><i class="bi bi-grid-3x3-gap-fill me-2"></i>EnterpriseCMS</h5>
                    <button class="btn btn-sm btn-outline-light" id="closeMobileSidebar"><i class="bi bi-x"></i></button>
                </div>
                <hr class="border-secondary" />
                <ul class="nav nav-pills flex-column mb-auto">
                    <li class="nav-item"><a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="nav-link text-white"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                    <li class="nav-item"><a asp-area="Admin" asp-controller="Content" asp-action="Index" class="nav-link text-white"><i class="bi bi-file-earmark-text me-2"></i>Content</a></li>
                    <li class="nav-item"><a asp-area="Admin" asp-controller="Media" asp-action="Index" class="nav-link text-white"><i class="bi bi-images me-2"></i>Media</a></li>
                    <li class="nav-item"><a asp-area="Admin" asp-controller="Menu" asp-action="Index" class="nav-link text-white"><i class="bi bi-list-nested me-2"></i>Menus</a></li>
                    <li class="nav-item"><a asp-area="Admin" asp-controller="Settings" asp-action="Index" class="nav-link text-white"><i class="bi bi-gear me-2"></i>Settings</a></li>
                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Administrator"))
                    {
                        <li class="nav-item"><a asp-area="Admin" asp-controller="Users" asp-action="Index" class="nav-link text-white"><i class="bi bi-people me-2"></i>Users</a></li>
                    }
                </ul>
            </div>
            <div class="container-fluid p-4">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/admin.js" asp-append-version="true"></script>
    <script>
        // Mobile sidebar toggle
        document.getElementById('sidebarToggle')?.addEventListener('click', function() {
            const ms = document.getElementById('mobileSidebar');
            if (ms) ms.style.setProperty('display', 'flex', 'important');
        });
        document.getElementById('closeMobileSidebar')?.addEventListener('click', function() {
            const ms = document.getElementById('mobileSidebar');
            if (ms) ms.style.setProperty('display', 'none', 'important');
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
