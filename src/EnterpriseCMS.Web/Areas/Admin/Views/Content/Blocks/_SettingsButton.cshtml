@{
    var blockId = ViewBag.BlockId as string ?? "";
}
<div data-block-id="@blockId">
    <h6 class="fw-semibold mb-3"><i class="bi bi-hand-index-thumb me-1"></i> Button Settings</h6>
    <div class="mb-2">
        <label class="form-label small">Label</label>
        <input type="text" class="form-control form-control-sm" placeholder="Click Me" data-field="label" />
    </div>
    <div class="mb-2">
        <label class="form-label small">URL</label>
        <input type="text" class="form-control form-control-sm" placeholder="https://..." data-field="url" />
    </div>
    <div class="mb-2">
        <label class="form-label small">Style</label>
        <select class="form-select form-select-sm" data-field="style">
            <option value="primary">Primary</option>
            <option value="secondary">Secondary</option>
            <option value="outline-primary">Outline Primary</option>
            <option value="success">Success</option>
            <option value="danger">Danger</option>
        </select>
    </div>
    <div class="mb-2">
        <label class="form-label small">Size</label>
        <select class="form-select form-select-sm" data-field="size">
            <option value="sm">Small</option>
            <option value="" selected>Normal</option>
            <option value="lg">Large</option>
        </select>
    </div>
    <div class="mb-2">
        <label class="form-label small">Target</label>
        <select class="form-select form-select-sm" data-field="target">
            <option value="_self" selected>Same Tab</option>
            <option value="_blank">New Tab</option>
        </select>
    </div>
</div>
