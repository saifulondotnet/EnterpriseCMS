@{
    var blockId = ViewBag.BlockId as string ?? "";
}
<div data-block-id="@blockId">
    <h6 class="fw-semibold mb-3"><i class="bi bi-play-circle me-1"></i> Video Settings</h6>
    <div class="mb-2">
        <label class="form-label small">Video URL (YouTube/Vimeo/direct)</label>
        <input type="text" class="form-control form-control-sm" placeholder="https://..." data-field="url" />
    </div>
    <div class="mb-2 form-check">
        <input type="checkbox" class="form-check-input" id="video-autoplay-@blockId" data-field="autoplay" />
        <label class="form-check-label small" for="video-autoplay-@blockId">Autoplay</label>
    </div>
    <div class="mb-2 form-check">
        <input type="checkbox" class="form-check-input" id="video-muted-@blockId" data-field="muted" />
        <label class="form-check-label small" for="video-muted-@blockId">Muted</label>
    </div>
    <div class="mb-2 form-check">
        <input type="checkbox" class="form-check-input" id="video-loop-@blockId" data-field="loop" />
        <label class="form-check-label small" for="video-loop-@blockId">Loop</label>
    </div>
</div>
