@{
    var blockId = ViewBag.BlockId as string ?? "";
}
<div data-block-id="@blockId">
    <h6 class="fw-semibold mb-3"><i class="bi bi-textarea-t me-1"></i> Rich Text Settings</h6>
    <div class="mb-2">
        <label class="form-label small">Content</label>
        <textarea id="richtext-editor-@blockId" class="form-control form-control-sm" rows="6" data-field="content"></textarea>
    </div>
</div>
