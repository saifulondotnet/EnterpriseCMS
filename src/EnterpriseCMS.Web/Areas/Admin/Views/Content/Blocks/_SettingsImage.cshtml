@{
    var blockId = ViewBag.BlockId as string ?? "";
}
<div data-block-id="@blockId">
    <h6 class="fw-semibold mb-3"><i class="bi bi-image me-1"></i> Image Settings</h6>
    <div class="mb-2">
        <label class="form-label small">Image URL</label>
        <input type="text" class="form-control form-control-sm" placeholder="https://..." data-field="src" />
    </div>
    <div class="mb-2">
        <label class="form-label small">Alt Text</label>
        <input type="text" class="form-control form-control-sm" placeholder="Descriptive alt text" data-field="alt" />
    </div>
    <div class="mb-2">
        <label class="form-label small">Caption</label>
        <input type="text" class="form-control form-control-sm" placeholder="Optional caption" data-field="caption" />
    </div>
    <div class="mb-2">
        <label class="form-label small">Alignment</label>
        <select class="form-select form-select-sm" data-field="alignment">
            <option value="left">Left</option>
            <option value="center" selected>Center</option>
            <option value="right">Right</option>
        </select>
    </div>
</div>
