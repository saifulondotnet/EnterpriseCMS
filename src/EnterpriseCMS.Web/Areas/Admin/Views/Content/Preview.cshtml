@using EnterpriseCMS.Application.Common.Models
@model ContentDto
@{
    ViewData["Title"] = "Preview: " + Model.Title;
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@Model.Title — Preview</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body { background: #f8f9fa; }
        .preview-bar { background: #212529; color: #fff; padding: 8px 16px; position: sticky; top: 0; z-index: 1000; }
    </style>
</head>
<body>
<div class="preview-bar d-flex align-items-center gap-3">
    <span class="badge bg-warning text-dark">PREVIEW</span>
    <strong>@Model.Title</strong>
    <span class="badge bg-secondary">@Model.Status</span>
    <a href="javascript:window.close()" class="btn btn-sm btn-outline-light ms-auto">Close Preview</a>
</div>
<div class="container py-5">
    <h1 class="mb-3">@Model.Title</h1>
    @if (!string.IsNullOrEmpty(Model.Excerpt))
    {
        <p class="lead text-muted">@Model.Excerpt</p>
    }
    @if (!string.IsNullOrEmpty(Model.Body))
    {
        <div class="content-body">@Html.Raw(Model.Body)</div>
    }
</div>
</body>
</html>
